<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <handlers>
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <aspNetCore processPath="dotnet" arguments=".\TaoyuanDMS.API.dll" stdoutLogEnabled="false" hostingModel="inprocess">
        <environmentVariables>
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
        </environmentVariables>
      </aspNetCore>

      <!--
        OnlyOffice 反向代理：
        瀏覽器請求 https://<DMS-VM>/onlyoffice/web-apps/apps/api/documents/api.js
        → IIS 轉發到 http://192.168.50.10/web-apps/apps/api/documents/api.js
        這樣前端就不會因為 mixed-content (https→http) 或跨網段被擋。
        前置條件：IIS 須安裝 URL Rewrite + Application Request Routing (ARR)，
        並在 ARR 設定中啟用 "Enable proxy"。
      -->
      <rewrite>
        <rules>
          <rule name="OnlyOfficeProxy" stopProcessing="true">
            <match url="^onlyoffice/(.*)" />
            <action type="Rewrite" url="http://192.168.50.10/{R:1}" />
          </rule>
        </rules>
      </rewrite>
    </system.webServer>
  </location>
</configuration>
